{
  "name": "@unio/outport-arcade",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Outport mini-games engine + games (Bayman, Cod Jigger, Overboard, Woodpile, Kung Fu Overdrive)",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/myunio/outport-arcade.git"
  },
  "main": "./src/index.js",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./dist/outport-arcade.esm.js"
    },
    "./host": "./src/host/game_host.js",
    "./games/*": "./src/games/*/index.js",
    "./assets/*": "./assets/*",
    "./assets-manifest": "./src/assets-manifest.js"
  },
  "files": [
    "src",
    "assets",
    "dist"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "prepare": "pnpm run build",
    "build": "node build.js"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
